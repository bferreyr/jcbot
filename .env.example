# PORT
PORT=3001

# GOOGLE GEMINI API
GEMINI_API_KEY=your_gemini_api_key_here

# WHATSAPP API (META)
WHATSAPP_TOKEN=your_whatsapp_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
WEBHOOK_VERIFY_TOKEN=your_custom_verify_token_here

# DATABASE (POSTGRESQL)
DATABASE_URL="postgresql://jcbot_user:usuario@localhost:5432/jcbot?schema=public"

# GOOGLE SHEETS
# Ruta al archivo JSON de credenciales de Google Service Account.
# Por ejemplo: ./google-credentials.json
GOOGLE_APPLICATION_CREDENTIALS_PATH=
# ID de la planilla (Se obtiene de la URL de Google Sheets)
GOOGLE_SPREADSHEET_ID=
REPARACIONES_SPREADSHEET_ID=
PLAN_CANJE_SPREADSHEET_ID=
